{
    "name": "@oagent/oa",
    "version": "1.0.1",
    "main": "./dist/index.js",
    "type": "module",
    "private": false,
    "description": "基于 Ink + AI SDK 的终端 AI Agent 客户端，支持文件读写、代码搜索、网页搜索、Skill 扩展等工具调用",
    "bin": {
        "oa": "./dist/index.js"
    },
    "files": [
        "dist",
        "README.md",
        "config.example.json"
    ],
    "scripts": {
        "build": "pnpm -r --workspace-concurrency=1 build && tsup",
        "start": "tsx packages/core/src/index.tsx",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "typecheck": "pnpm -r typecheck",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "version:all": "bash scripts/version.sh",
        "publish:all": "bash scripts/publish.sh",
        "prepare": "husky",
        "commit": "git-cz"
    },
    "keywords": [
        "tui",
        "ink",
        "ai-agent",
        "cli"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@oagent/core": "workspace:*"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@types/node": "^25.9.1",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^10.1.0",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-unused-imports": "^4.4.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "tsup": "^8.5.1",
        "tsx": "^4.22.3",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.57.2"
    },
    "engines": {
        "node": ">=22",
        "pnpm": ">=10.32.1"
    },
    "config": {
        "commitizen": {
            "path": "./node_modules/cz-conventional-changelog"
        }
    },
    "packageManager": "pnpm@10.33.0"
}
